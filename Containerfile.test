# ========================================================================
# Project: pharos
# Component: DevSecOps Foundation
# File: Containerfile.test
# Author: Richard D. (https://github.com/iamrichardd)
# License: AGPL-3.0 (See LICENSE file for details)
# * Purpose (The "Why"):
# This file provides an isolated, automated test environment for pharos.
# It is used for CI/CD, unit tests, and regression verification inside a container.
# * Traceability:
# Related to Task 1.2, Issue #2
# ========================================================================

FROM public.ecr.aws/docker/library/ubuntu:24.04

# Prevent interactive prompts
ARG DEBIAN_FRONTEND=noninteractive

# Install core dependencies (minimal for testing)
RUN apt-get update && apt-get install -y \
    curl \
    pkg-config \
    libssl-dev \
    build-essential \
    lld \
    ca-certificates \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 (LTS) for Web Console tests
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

# Install Playwright dependencies (Headless Chromium)
RUN npx -y playwright install-deps chromium && \
    npx -y playwright install chromium

# Install Netcat for protocol testing
RUN apt-get update && apt-get install -y netcat-openbsd && rm -rf /var/lib/apt/lists/*

# Install Gitleaks for secret detection
RUN GITLEAKS_VERSION=$(curl -s https://api.github.com/repos/gitleaks/gitleaks/releases/latest | grep '"tag_name":' | sed -E 's/.*"v([^"]+)".*/\1/') && \
    curl -fSL "https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz" -o gitleaks.tar.gz && \
    tar -xzf gitleaks.tar.gz gitleaks && \
    mv gitleaks /usr/local/bin/ && \
    rm gitleaks.tar.gz

# Install Rust via rustup
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:${PATH}"

# Install Cargo Audit for DevSecOps vulnerability scanning
RUN cargo install cargo-audit

# Set up working directory
WORKDIR /workspace

# Default command for tests
CMD ["cargo", "test", "--all-features"]
