# ========================================================================
# Project: pharos
# Component: Web Console
# File: pharos-console-web/Containerfile
# Author: Richard D. (https://github.com/iamrichardd)
# License: AGPL-3.0 (See LICENSE file for details)
# * Purpose (The "Why"):
# Production build and runtime for the Pharos Web Console (Astro SSR).
# Provides a lightweight, self-contained environment for Home Lab/Enterprise.
# * Traceability:
# Related to Task 16.1 in Phase 16.
# ========================================================================

FROM public.ecr.aws/docker/library/node:22-slim AS build

WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

FROM public.ecr.aws/docker/library/node:22-slim AS runtime

LABEL org.opencontainers.image.title="pharos-console-web"
LABEL org.opencontainers.image.description="Agent-Native Control Plane (Web Console)"
LABEL org.opencontainers.image.vendor="Richard D."
LABEL org.opencontainers.image.licenses="AGPL-3.0"
LABEL org.opencontainers.image.source="https://github.com/iamrichardd/pharos"

WORKDIR /app
RUN apt-get update && apt-get install -y tini && rm -rf /var/lib/apt/lists/*
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json
COPY --from=build /app/server.mjs ./server.mjs

ENV HOST=0.0.0.0
ENV PORT=3000
EXPOSE 3000

# Start with tini for proper signal handling in Node.js
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "./server.mjs"]
