---
/* ========================================================================
 * Project: pharos
 * Component: Web Console
 * File: src/features/pulse/monitor/PulseMonitor.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: AGPL-3.0 (See LICENSE file for details)
 * * Purpose (The "Why"):
 * A real-time dashboard component that displays the status of all nodes
 * being monitored by pharos-pulse. Provides visual health indicators.
 * * Traceability:
 * Related to Task 16.4 (Issue #66).
 * ======================================================================== */
import { getPulseStatus } from './pulse-logic';

const machines = await getPulseStatus();
---

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold text-slate-950">Active Nodes</h2>
        <div class="flex items-center space-x-2">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                {machines.filter(m => m.status === 'ONLINE').length} Online
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                {machines.filter(m => m.status === 'UNREACHABLE').length} Unreachable
            </span>
        </div>
    </div>

    {machines.length === 0 ? (
        <div class="p-12 text-center bg-white border border-slate-200 rounded-3xl">
            <div class="mx-auto w-16 h-16 bg-slate-50 text-slate-300 rounded-full flex items-center justify-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
            </div>
            <p class="text-slate-600 font-medium">No pulse signals detected yet.</p>
            <p class="text-slate-400 text-sm mt-1">Start the `pharos-pulse` agent on your machines to see them here.</p>
        </div>
    ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {machines.map(machine => (
                <div class="p-5 bg-white border border-slate-200 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between mb-4">
                        <div class="space-y-0.5">
                            <h3 class="font-bold text-slate-900 truncate max-w-[150px]" title={machine.hostname}>{machine.hostname}</h3>
                            <p class="text-xs text-slate-500 italic">
                                {machine.status === 'OFFLINE' ? 'Last seen: shutdown' : 'Status: Online'}
                            </p>
                        </div>
                        <span class={`h-2.5 w-2.5 rounded-full ring-4 ring-offset-2 ${machine.status === 'ONLINE' ? 'bg-green-500 ring-green-100' : (machine.status === 'OFFLINE' ? 'bg-slate-300 ring-slate-100' : 'bg-red-500 ring-red-100')}`}></span>
                    </div>

                    <div class="space-y-3">
                        <div class="flex items-center space-x-2 text-xs text-slate-600 bg-slate-50 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                            </svg>
                            <span class="truncate">{machine.cpuBrand || 'Unknown CPU'}</span>
                            <span class="font-bold border-l border-slate-200 pl-2">{machine.cpuCores} cores</span>
                        </div>

                        <div class="flex items-center space-x-2 text-xs text-slate-600 bg-slate-50 p-2 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                            <span>{machine.osName} {machine.osVersion}</span>
                        </div>

                        <div class="flex justify-between items-center pt-2 mt-2 border-t border-slate-100">
                            <div class="flex flex-col">
                                <span class="text-[10px] uppercase tracking-wider text-slate-400 font-bold">Serial Number</span>
                                <span class="text-xs font-mono text-slate-600">{machine.serialNumber || 'N/A'}</span>
                            </div>
                            <a href={`/mdb/${machine.hostname}`} class="text-xs font-bold text-blue-600 hover:text-blue-700 flex items-center">
                                Details
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    )}
</div>
