---
/* ========================================================================
 * Project: pharos
 * Component: Web Console
 * File: src/features/mdb/search/MdbSearchForm.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: AGPL-3.0 (See LICENSE file for details)
 * * Purpose (The "Why"):
 * UI component for the MDB search form. Mobile-first design with
 * consistent styling and clear visual cues.
 * * Traceability:
 * Related to Task 16.6 (Issue #69).
 * ======================================================================== */
interface Props {
    query: string;
}

const { query } = Astro.props;
---

<form method="get" action="/mdb" class="flex flex-col sm:flex-row gap-3">
    <div class="relative flex-grow">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-slate-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
        </div>
        <input
            type="text"
            name="q"
            id="search"
            class="block w-full pl-10 pr-3 py-3 border border-slate-300 rounded-xl focus:ring-emerald-500 focus:border-emerald-500 bg-white shadow-sm text-lg"
            placeholder="e.g., *"
            value={query}
            autofocus
        />
    </div>
    <button
        type="submit"
        class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-xl shadow-sm text-white bg-emerald-600 hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 transition-colors"
    >
        Search
    </button>
</form>

<div class="flex flex-wrap items-center gap-2 mt-3">
    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mr-1">Examples:</span>
    {[
        { label: 'All Records', query: '*' },
        { label: 'Online Only', query: 'status=online' },
        { label: 'By Hostname', query: 'hostname=pharos-*' },
        { label: 'By OS', query: 'os_name=debian' }
    ].map((example) => (
        <button
            type="button"
            class="example-btn px-2.5 py-1 text-xs font-medium bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 hover:text-slate-900 transition-colors border border-slate-200"
            data-query={example.query}
        >
            {example.label}
        </button>
    ))}
</div>

<div id="cli-hint" class="mt-4 p-3 bg-slate-50 border border-slate-200 rounded-xl flex items-center justify-between group">
    <div class="flex items-center space-x-2 text-xs text-slate-500">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        <span><strong>Power User Hint:</strong> Use the CLI toolbelt for faster queries:</span>
        <code class="bg-slate-200 px-1.5 py-0.5 rounded text-slate-700 font-mono">mdb "{query || '*'}"</code>
    </div>
    <a href="https://iamrichardd.com/pharos/docs/cli-clients" target="_blank" class="text-[10px] font-bold text-emerald-600 hover:text-emerald-500 uppercase tracking-wider group-hover:translate-x-0.5 transition-transform">
        CLI Docs &rarr;
    </a>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        const searchInput = document.querySelector('#search') as HTMLInputElement;
        const exampleBtns = document.querySelectorAll('.example-btn');

        exampleBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const query = btn.getAttribute('data-query');
                if (query && searchInput) {
                    searchInput.value = query;
                    searchInput.focus();
                    // Optionally auto-submit:
                    // searchInput.closest('form')?.submit();
                }
            });
        });
    });
</script>
