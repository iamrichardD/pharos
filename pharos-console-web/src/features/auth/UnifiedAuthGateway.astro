---
/* ========================================================================
 * Project: pharos
 * Component: Web Console
 * File: src/features/auth/UnifiedAuthGateway.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: AGPL-3.0 (See LICENSE file for details)
 * * Purpose (The "Why"):
 * A unified, tabbed authentication component that consolidates Standard, 
 * CLI Handshake, and Enterprise login methods into a single, cohesive UI.
 * Reduces cognitive load and vertical clutter.
 * * Traceability:
 * Related to Task 16.14 (Issue #102).
 * ======================================================================== */
const challenge = crypto.randomUUID();
const isSandbox = process.env.PHAROS_SANDBOX === 'true';
const commandHint = isSandbox 
    ? `podman exec -it pharos-pulse mdb auth sign ${challenge}`
    : `mdb auth sign ${challenge}`;
---

<div class="max-w-md w-full mx-auto" id="authGateway">
    <!-- Tab Navigation -->
    <div class="flex p-1 bg-slate-100 rounded-2xl mb-4 border border-slate-200">
        <button 
            data-tab="standard" 
            class="tab-btn flex-1 py-2 px-4 rounded-xl text-sm font-bold transition-all bg-white shadow-sm text-slate-950"
        >
            Home Lab
        </button>
        <button 
            data-tab="handshake" 
            class="tab-btn flex-1 py-2 px-4 rounded-xl text-sm font-bold transition-all text-slate-500 hover:text-slate-700"
        >
            DevSecOps
        </button>
        <button 
            data-tab="enterprise" 
            class="tab-btn flex-1 py-2 px-4 rounded-xl text-sm font-bold transition-all text-slate-500 hover:text-slate-700"
        >
            Enterprise
        </button>
    </div>

    <!-- Tab Content: Standard -->
    <div id="standardPanel" class="tab-panel p-8 bg-white border border-slate-200 rounded-3xl shadow-sm space-y-8">
        <div class="text-center">
            <h1 class="text-2xl font-extrabold text-slate-950">Welcome back</h1>
            <p class="text-slate-600">Please enter your credentials to manage your lab</p>
        </div>

        <form method="POST" class="space-y-6" id="loginForm">
            <div class="space-y-2">
                <label for="username" class="text-sm font-semibold text-slate-700">Username</label>
                <input 
                    type="text" 
                    id="username" 
                    name="username" 
                    required 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-hidden"
                    placeholder="e.g. admin"
                />
            </div>

            <div class="space-y-2">
                <label for="password" class="text-sm font-semibold text-slate-700">Password</label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    required 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-hidden"
                    placeholder="••••••••"
                />
            </div>

            <button 
                type="submit" 
                class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl shadow-lg shadow-blue-200 transition-all hover:-translate-y-0.5"
            >
                Sign in
            </button>
        </form>
    </div>

    <!-- Tab Content: CLI Handshake -->
    <div id="handshakePanel" class="tab-panel hidden p-8 bg-white border border-slate-200 rounded-3xl shadow-sm space-y-6">
        <div class="space-y-2 text-center">
            <h2 class="text-2xl font-extrabold text-slate-950">CLI Handshake</h2>
            <p class="text-sm text-slate-600">Run the command below in your terminal to sign in with SSH keys.</p>
        </div>

        <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 font-mono text-xs text-blue-400 break-all select-all shadow-inner">
            {commandHint}
        </div>

        <form id="handshakeForm" class="space-y-6">
            <input type="hidden" name="challenge" value={challenge} />
            <div class="space-y-2">
                <label for="publicKey" class="text-sm font-semibold text-slate-700">Public Key</label>
                <input 
                    type="text" 
                    id="publicKey" 
                    name="publicKey" 
                    required 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-hidden text-sm font-mono"
                    placeholder="ssh-ed25519 ..."
                />
            </div>
            <div class="space-y-2">
                <label for="signature" class="text-sm font-semibold text-slate-700">Signature</label>
                <input 
                    type="text" 
                    id="signature" 
                    name="signature" 
                    required 
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-hidden text-sm font-mono"
                    placeholder="Base64 signature"
                />
            </div>
            <button 
                type="submit" 
                class="w-full py-4 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-xl transition-all hover:-translate-y-0.5 shadow-lg shadow-slate-200"
            >
                Verify Handshake
            </button>
        </form>
    </div>

    <!-- Tab Content: Enterprise SSO -->
    <div id="enterprisePanel" class="tab-panel hidden p-8 bg-white border border-slate-200 rounded-3xl shadow-sm space-y-6">
        <div class="space-y-2 text-center">
            <h2 class="text-2xl font-extrabold text-slate-950">Enterprise SSO</h2>
            <p class="text-sm text-slate-600">Sign in with your corporate identity provider.</p>
        </div>

        <div class="py-8 flex flex-col gap-4">
            <button id="ssoBtn" class="w-full py-4 bg-white border border-slate-200 hover:bg-slate-50 rounded-xl font-bold transition-all flex items-center justify-center gap-3 text-slate-950 shadow-sm">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.545,10.239v3.821h5.445c-0.712,2.315-2.647,3.972-5.445,3.972c-3.332,0-6.033-2.701-6.033-6.032 s2.701-6.032,6.033-6.032c1.498,0,2.866,0.549,3.921,1.453l2.814-2.814C17.503,2.988,15.139,2,12.545,2 C7.021,2,2.543,6.477,2.543,12s4.478,10,10.002,10c8.396,0,10.249-7.85,9.426-11.748L12.545,10.239z"/>
                </svg>
                Continue with OIDC
            </button>
            <p class="text-center text-xs text-slate-400">Supported: Azure AD, Okta, Keycloak</p>
        </div>
    </div>

    <p id="errorMessage" class="mt-4 hidden text-center text-sm font-medium text-red-600 bg-red-50 p-3 rounded-xl border border-red-100"></p>
</div>

<script>
    import { actions } from 'astro:actions';
    import { navigate } from 'astro:transitions/client';

    document.addEventListener('astro:page-load', () => {
        const loginForm = document.querySelector('#loginForm') as HTMLFormElement;
        const handshakeForm = document.querySelector('#handshakeForm') as HTMLFormElement;
        const ssoBtn = document.querySelector('#ssoBtn') as HTMLButtonElement;
        const errorMsg = document.querySelector('#errorMessage') as HTMLParagraphElement;
        const tabBtns = document.querySelectorAll('.tab-btn');
        const tabPanels = document.querySelectorAll('.tab-panel');

        // Tab Logic
        tabBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const target = btn.getAttribute('data-tab');
                
                // Update buttons
                tabBtns.forEach(b => {
                    b.classList.remove('bg-white', 'shadow-sm', 'text-slate-950');
                    b.classList.add('text-slate-500');
                });
                btn.classList.add('bg-white', 'shadow-sm', 'text-slate-950');
                btn.classList.remove('text-slate-500');

                // Update panels
                tabPanels.forEach(p => p.classList.add('hidden'));
                document.getElementById(`${target}Panel`)?.classList.remove('hidden');
                
                // Clear errors on tab change
                if (errorMsg) errorMsg.classList.add('hidden');
            });
        });

        if (loginForm) {
            loginForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (errorMsg) errorMsg.classList.add('hidden');
                
                const formData = new FormData(loginForm);
                const { data, error } = await actions.login(formData);

                if (error) {
                    if (errorMsg) {
                        errorMsg.textContent = error.message || 'Authentication failed';
                        errorMsg.classList.remove('hidden');
                    }
                } else {
                    if (data?.mustChangePassword) {
                        navigate('/change-password');
                    } else {
                        navigate('/');
                    }
                }
            });
        }

        if (handshakeForm) {
            handshakeForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (errorMsg) errorMsg.classList.add('hidden');
                
                const formData = new FormData(handshakeForm);
                const { error } = await actions.handshakeLogin(formData);

                if (error) {
                    if (errorMsg) {
                        errorMsg.textContent = error.message || 'Handshake verification failed';
                        errorMsg.classList.remove('hidden');
                    }
                } else {
                    navigate('/');
                }
            });
        }

        if (ssoBtn) {
            ssoBtn.addEventListener('click', () => {
                alert('Enterprise OIDC integration (Azure/Okta) is currently being scaffolded! Please use standard login for now.');
            });
        }
    });
</script>
