---
/* ========================================================================
 * Project: pharos
 * Component: Web Console
 * File: src/pages/change-password.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: AGPL-3.0 (See LICENSE file for details)
 * * Purpose (The "Why"):
 * Mandatory password change route for first-time logins. Ensures the
 * system transitions from insecure defaults to user-defined credentials.
 * * Traceability:
 * Related to Task 16.15 (Issue #113).
 * ======================================================================== */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import { getSession } from '../features/auth/session-logic';
import { AUTH_COOKIE_NAME } from '../features/auth/auth-config';

const session = await getSession(Astro.cookies.get(AUTH_COOKIE_NAME)?.value);

// Redirect to login if not authenticated
if (!session) {
    return Astro.redirect('/login');
}

// Redirect to home if password change is not required
if (!session.mustChangePassword) {
    return Astro.redirect('/');
}
---

<ConsoleLayout title="Secure Your Account">
    <div class="py-10 sm:py-20 flex flex-col items-center justify-center space-y-8">
        <div class="text-center space-y-2 mb-4">
            <h1 class="text-4xl font-extrabold text-slate-950 tracking-tight">
                Secure Your Lab
            </h1>
            <p class="text-slate-600 max-w-sm mx-auto">
                You are using a default password. Please choose a strong, unique password to continue.
            </p>
        </div>

        <div class="max-w-md w-full mx-auto p-8 bg-white border border-slate-200 rounded-3xl shadow-sm space-y-8">
            <form id="changePasswordForm" class="space-y-6">
                <div class="space-y-2">
                    <label for="password" class="text-sm font-semibold text-slate-700">New Password</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        required 
                        minlength="8"
                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-hidden"
                        placeholder="••••••••"
                    />
                    <p class="text-xs text-slate-400">Minimum 8 characters.</p>
                </div>

                <div class="space-y-2">
                    <label for="confirmPassword" class="text-sm font-semibold text-slate-700">Confirm Password</label>
                    <input 
                        type="password" 
                        id="confirmPassword" 
                        name="confirmPassword" 
                        required 
                        minlength="8"
                        class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-hidden"
                        placeholder="••••••••"
                    />
                </div>

                <button 
                    type="submit" 
                    class="w-full py-4 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl shadow-lg shadow-blue-200 transition-all hover:-translate-y-0.5"
                >
                    Update Password
                </button>
            </form>
            
            <p id="errorMessage" class="hidden text-center text-sm font-medium text-red-600 bg-red-50 p-3 rounded-xl border border-red-100"></p>
        </div>
        
        <p class="text-xs text-slate-400 text-center max-w-xs">
            Password hashes are stored locally using scrypt for cryptographic integrity.
        </p>
    </div>
</ConsoleLayout>

<script>
    import { actions } from 'astro:actions';
    import { navigate } from 'astro:transitions/client';

    document.addEventListener('astro:page-load', () => {
        const form = document.querySelector('#changePasswordForm') as HTMLFormElement;
        const errorMsg = document.querySelector('#errorMessage') as HTMLParagraphElement;

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                if (errorMsg) errorMsg.classList.add('hidden');
                
                const formData = new FormData(form);
                const { error } = await actions.updatePassword(formData);

                if (error) {
                    if (errorMsg) {
                        errorMsg.textContent = error.message || 'Failed to update password';
                        errorMsg.classList.remove('hidden');
                    }
                } else {
                    navigate('/');
                }
            });
        }
    });
</script>
