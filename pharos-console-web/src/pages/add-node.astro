---
/* ========================================================================
 * Project: pharos
 * Component: Web Console
 * File: src/pages/add-node.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: AGPL-3.0 (See LICENSE file for details)
 * * Purpose (The "Why"):
 * Provides a guided interface for adding new nodes to the Pharos network.
 * Offers both one-liner and containerized (Podman) installation commands.
 * * Traceability:
 * Related to Task 21.4 (Issue #133).
 * ======================================================================== */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';

const isSandbox = process.env.PHAROS_SANDBOX === 'true';
const pharosHost = process.env.PHAROS_HOST || 'pharos-server';
---

<ConsoleLayout title="Add Node">
    <div class="space-y-6 sm:space-y-8">
        <div>
            <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl tracking-tight">Add a New Node</h1>
            <p class="text-lg text-slate-600 mt-2">Expand your Pharos network by installing the Pulse agent on your target machines.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- One-Liner Card -->
            <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full">
                <div class="flex items-center space-x-3 mb-4">
                    <div class="bg-emerald-100 text-emerald-700 p-2 rounded-lg">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h2 class="text-xl font-bold text-slate-900">The One-Liner</h2>
                </div>
                <p class="text-slate-600 mb-6 flex-grow italic">Recommended for Ubuntu, Debian, macOS, or WSL hosts.</p>
                <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto relative group">
                    <code class="text-emerald-400 text-sm whitespace-nowrap">PHAROS_HOST="{pharosHost}" curl -sSL https://raw.githubusercontent.com/iamrichardD/pharos/main/scripts/install.sh | bash -s -- node</code>
                    <button class="absolute top-2 right-2 text-slate-400 hover:text-white transition-colors opacity-0 group-hover:opacity-100" onclick="navigator.clipboard.writeText(this.previousElementSibling.innerText)">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    </button>
                </div>
            </div>

            <!-- Podman Card -->
            <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full">
                <div class="flex items-center space-x-3 mb-4">
                    <div class="bg-blue-100 text-blue-700 p-2 rounded-lg">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                        </svg>
                    </div>
                    <h2 class="text-xl font-bold text-slate-900">Containerized (Podman)</h2>
                </div>
                <p class="text-slate-600 mb-6 flex-grow italic">Ideal for immutable hosts or container-first environments.</p>
                <div class="bg-slate-900 rounded-xl p-4 overflow-x-auto relative group">
                    <code class="text-blue-400 text-sm whitespace-nowrap">podman run -d --name pharos-pulse -e PHAROS_HOST={pharosHost} ghcr.io/iamrichardd/pharos-pulse:latest</code>
                    <button class="absolute top-2 right-2 text-slate-400 hover:text-white transition-colors opacity-0 group-hover:opacity-100" onclick="navigator.clipboard.writeText(this.previousElementSibling.innerText)">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6 space-y-4">
            <h3 class="text-lg font-bold text-slate-900">What happens next?</h3>
            <ul class="space-y-3">
                <li class="flex items-start space-x-3">
                    <div class="mt-1 bg-emerald-500 text-white rounded-full p-0.5">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <span class="text-slate-700">The agent will automatically register with the Pharos Hub.</span>
                </li>
                <li class="flex items-start space-x-3">
                    <div class="mt-1 bg-emerald-500 text-white rounded-full p-0.5">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <span class="text-slate-700">Machine metadata (CPU, RAM, Serial) will be collected as a baseline.</span>
                </li>
                <li class="flex items-start space-x-3">
                    <div class="mt-1 bg-emerald-500 text-white rounded-full p-0.5">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <span class="text-slate-700">The node will appear in the <strong>Search MDB</strong> results within 60 seconds.</span>
                </li>
            </ul>
        </div>

        <div class="flex justify-center">
            <a href="/mdb" class="text-emerald-600 font-medium hover:text-emerald-500 transition-colors flex items-center space-x-1">
                <span>Go to Search MDB</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
        </div>
    </div>
</ConsoleLayout>
