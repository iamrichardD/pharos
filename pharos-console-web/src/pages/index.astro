---
/* ========================================================================
 * Project: pharos
 * Component: Web Console
 * File: src/pages/index.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: AGPL-3.0 (See LICENSE file for details)
 * * Purpose (The "Why"):
 * The primary landing page for the Pharos Web Console. Provides entry 
 * points for MDB search, Pulse monitoring, and authentication.
 * * Traceability:
 * Related to Task 16.1 (Scaffolding), Task 16.2 (Mobile-First MDB), 
 * and Task 16.14 (Unified Gateway).
 * ======================================================================== */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import SandboxTerminal from '../features/sandbox/SandboxTerminal.astro';

const isSandbox = process.env.PHAROS_SANDBOX === 'true';
const session = Astro.locals.session;
---

<ConsoleLayout title="Home">
    <section class="space-y-6 sm:space-y-8 py-4 sm:py-8">
        <div class="space-y-4">
            <h1 class="text-3xl font-extrabold text-slate-950 sm:text-5xl tracking-tight">
                Manage your Home Lab & Enterprise Infrastructure
            </h1>
            <p class="text-lg text-slate-600 max-w-2xl leading-relaxed">
                A Human/AI/Mobile interface for the Pharos Protocol. Search machine records, monitor node presence, and manage infrastructure on the go.
            </p>
        </div>

        {!session && (
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/login" class="px-8 py-4 bg-slate-900 text-white rounded-2xl font-bold shadow-lg shadow-slate-200 hover:-translate-y-0.5 transition-all text-center">
                    Get Started
                </a>
                <a href="https://iamrichardd.com/pharos/docs/" class="px-8 py-4 bg-white border border-slate-200 text-slate-950 rounded-2xl font-bold hover:bg-slate-50 transition-all text-center">
                    Read Documentation
                </a>
            </div>
        )}
    </section>

    {isSandbox && (
        <SandboxTerminal />
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4 sm:mt-8">
        <!-- MDB Search Card -->
        <a href="/mdb" class="group p-6 bg-white border border-slate-200 rounded-3xl shadow-xs hover:shadow-md transition-all hover:border-blue-400">
            <div class="h-12 w-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-4 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <h2 class="text-xl font-bold text-slate-950 mb-1">Search MDB</h2>
            <p class="text-slate-600 text-sm">Find IP addresses, MACs, and device metadata across your network.</p>
        </a>
    </div>
</ConsoleLayout>
