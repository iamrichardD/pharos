---
/* ========================================================================
 * Project: pharos
 * Component: Web Console
 * File: src/pages/login.astro
 * Author: Richard D. (https://github.com/iamrichardd)
 * License: AGPL-3.0 (See LICENSE file for details)
 * * Purpose (The "Why"):
 * The dedicated login route. Provides a focused, unified authentication 
 * interface that redirects to the home page upon successful session creation.
 * * Traceability:
 * Related to Task 16.4 (Issue #66) and Task 16.14 (Issue #102).
 * ======================================================================== */
import ConsoleLayout from '../layouts/ConsoleLayout.astro';
import UnifiedAuthGateway from '../features/auth/UnifiedAuthGateway.astro';
import { getSession } from '../features/auth/session-logic';
import { AUTH_COOKIE_NAME } from '../features/auth/auth-config';

const session = await getSession(Astro.cookies.get(AUTH_COOKIE_NAME)?.value);

// Redirect to home if already logged in
if (session) {
    return Astro.redirect('/');
}
---

<ConsoleLayout title="Sign In">
    <div class="py-10 sm:py-20 flex flex-col items-center justify-center space-y-8">
        <div class="text-center space-y-2 mb-4">
            <h1 class="text-4xl font-extrabold text-slate-950 tracking-tight">
                Secure Gateway
            </h1>
            <p class="text-slate-600 max-w-sm mx-auto">
                Authenticate to manage your Pharos-powered infrastructure.
            </p>
        </div>

        <UnifiedAuthGateway />
        
        <p class="text-xs text-slate-400 text-center max-w-xs">
            By signing in, you agree to the AGPL-3.0 licensing terms of the Pharos Protocol.
        </p>
    </div>
</ConsoleLayout>
