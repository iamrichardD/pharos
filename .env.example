# ========================================================================
# Project: pharos
# Component: Environment Configuration
# File: .env.example
# Author: Richard D. (https://github.com/iamrichardd)
# License: AGPL-3.0 (See LICENSE file for details)
# * Purpose (The "Why"):
# Standardized environment variables for the Pharos ecosystem.
# Ensures port consistency across Server, CLI, and Web Console.
# ========================================================================

# --- Networking ---
# The standard Pharos protocol port (RFC 2378)
PHAROS_PORT=2378
PHAROS_ADDR=0.0.0.0:2378

# The Web Console access port
PHAROS_WEB_PORT=3000

# The Prometheus metrics port
PHAROS_METRICS_PORT=9090

# --- Storage ---
# Unset for MemoryStorage (Dev Tier)
# PHAROS_STORAGE_PATH=./pharos.json

# --- Security ---
# Tiers: open, protected, scoped
PHAROS_SECURITY_TIER=open
PHAROS_KEYS_DIR=./keys

# --- Enterprise (LDAP) ---
# PHAROS_LDAP_URL=ldap://localhost:389
# PHAROS_LDAP_BIND_DN=cn=admin,dc=example,dc=org
# PHAROS_LDAP_BIND_PW=admin
# PHAROS_LDAP_BASE_DN=dc=example,dc=org
